<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS : bloquer accès SQLite, rl_logs, config, .env, .log.
  Pour les règles "rewrite", le module "URL Rewrite" doit être installé.
  Sans lui, .sqlite et le dossier rl_logs restent protégés (requestFiltering).
-->
<configuration>
  <system.webServer>
    <!-- Bloquer l'accès aux fichiers et dossiers sensibles -->
    <security>
      <requestFiltering>
        <!-- Extension .sqlite : pas de téléchargement -->
        <fileExtensions>
          <add fileExtension=".sqlite" allowed="false" />
        </fileExtensions>
        <!-- Dossier rl_logs : masqué et inaccessible -->
        <hiddenSegments>
          <add segment="rl_logs" />
          <add segment="data" />
        </hiddenSegments>
      </requestFiltering>
    </security>
    <!-- Refuser explicitement l'accès aux fichiers de config (secrets) -->
    <rewrite>
      <rules>
        <rule name="Block config-intranet php" stopProcessing="true">
          <match url="^config-intranet(-[^.]*)?\.php$" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" />
        </rule>
        <rule name="Block rl_logs" stopProcessing="true">
          <match url="^rl_logs(/.*)?$" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" />
        </rule>
        <rule name="Block data folder" stopProcessing="true">
          <match url="^data(/.*)?$" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" />
        </rule>
        <rule name="Block env and log files" stopProcessing="true">
          <match url=".*\.(env|log)$" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
